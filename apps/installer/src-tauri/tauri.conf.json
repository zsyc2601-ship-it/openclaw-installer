{
  "$schema": "https://raw.githubusercontent.com/nicegram/nicegram-tauri/main/crates/tauri-utils/schema.json",
  "productName": "OpenClaw Installer",
  "version": "0.1.0",
  "identifier": "com.openclaw.installer",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "OpenClaw 安装器",
        "width": 520,
        "height": 680,
        "resizable": false,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/*"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
